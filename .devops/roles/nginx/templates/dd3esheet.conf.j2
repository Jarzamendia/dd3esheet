# ============================================================
# Nginx — Reverse Proxy para DD3ESheet
# Gerado pelo Ansible — NÃO editar manualmente
# ============================================================

upstream dd3esheet_app {
    server 127.0.0.1:{{ app_port }};
}

server {
    listen 80;
    listen [::]:80;
    server_name {{ app_domain }};

    # --- Logs ---
    access_log /var/log/nginx/dd3esheet_access.log;
    error_log  /var/log/nginx/dd3esheet_error.log;

    # --- Limites ---
    client_max_body_size 10M;

    # --- Headers de segurança ---
    include /etc/nginx/snippets/security-headers.conf;

    # --- Arquivos estáticos (servidos direto pelo Nginx) ---
    location /static/ {
        alias {{ app_dir }}/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location /media/ {
        alias {{ app_dir }}/media/;
        expires 7d;
        add_header Cache-Control "public";
        access_log off;
    }

    # --- Favicon ---
    location = /favicon.ico {
        alias {{ app_dir }}/staticfiles/favicon.ico;
        access_log off;
        log_not_found off;
    }

    # --- Healthcheck (direto, sem proxy) ---
    location = /healthz {
        proxy_pass http://dd3esheet_app;
        proxy_set_header Host $host;
        access_log off;
    }

    # --- Proxy para a aplicação Django/Gunicorn ---
    location / {
        proxy_pass http://dd3esheet_app;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;

        # Buffers
        proxy_buffering on;
        proxy_buffer_size 8k;
        proxy_buffers 8 8k;
    }

    # --- Negar acesso a arquivos ocultos ---
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
}
