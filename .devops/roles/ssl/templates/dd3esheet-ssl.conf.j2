# ============================================================
# Nginx — Reverse Proxy com SSL para DD3ESheet
# Gerado pelo Ansible — NÃO editar manualmente
# Ambiente SSL: {{ ssl_environment | upper }}
# ============================================================

upstream dd3esheet_app {
    server 127.0.0.1:{{ app_port }};
}

# ── Redirecionar HTTP → HTTPS ─────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name {{ app_domain }};

    # Permitir desafio ACME (renovação de certificado)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

    # Redirecionar todo o resto para HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# ── Servidor HTTPS ─────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ app_domain }};

    # --- Certificados Let's Encrypt ---
    ssl_certificate     /etc/letsencrypt/live/{{ app_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ app_domain }}/privkey.pem;

    # --- Parâmetros SSL ---
    include /etc/nginx/snippets/ssl-params.conf;

    # --- Logs ---
    access_log /var/log/nginx/dd3esheet_access.log;
    error_log  /var/log/nginx/dd3esheet_error.log;

    # --- Limites ---
    client_max_body_size {{ nginx_client_max_body_size }};

    # --- Headers de segurança ---
    include /etc/nginx/snippets/security-headers.conf;

    # --- HSTS (apenas em produção) ---
{% if ssl_environment == 'production' %}
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
{% else %}
    # HSTS desabilitado em staging para facilitar testes
{% endif %}

    # --- Arquivos estáticos (servidos direto pelo Nginx) ---
    location /static/ {
        alias {{ app_dir }}/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location /media/ {
        alias {{ app_dir }}/media/;
        expires 7d;
        add_header Cache-Control "public";
        access_log off;
    }

    # --- Favicon ---
    location = /favicon.ico {
        alias {{ app_dir }}/staticfiles/favicon.ico;
        access_log off;
        log_not_found off;
    }

    # --- Healthcheck ---
    location = /healthz {
        proxy_pass http://dd3esheet_app;
        proxy_set_header Host $host;
        access_log off;
    }

    # --- Proxy para a aplicação Django/Gunicorn ---
    location / {
        proxy_pass http://dd3esheet_app;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;

        # Buffers
        proxy_buffering on;
        proxy_buffer_size 8k;
        proxy_buffers 8 8k;
    }

    # --- Negar acesso a arquivos ocultos ---
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
}
